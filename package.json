{
  "name": "gestion-equipement-it",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "backend": "node --env-file=.env server/server.js",
    "dev:all": "concurrently \"npm run backend\" \"npm run dev\"",
    "migrate": "node --env-file=.env server/migrate.js",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "node --env-file=.env server/server.js",
    "deploy": "npm run build && npm run start"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "docx": "^9.7.1",
    "express": "^5.2.1",
    "jsbarcode": "^3.12.3",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.469.0",
    "nodemailer": "^8.0.10",
    "pg": "^8.13.1",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.37",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.1"
  }
}
