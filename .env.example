# ─── Server Configuration ───
PORT=4000
NODE_ENV=development

# ─── Database ───
# PostgreSQL connection string (local or remote)
# Format: postgresql://username:password@host:port/database
# For Neon: postgresql://username:password@ep-xxx.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/gestion_it

# ─── JWT Configuration ───
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_EXPIRES_IN=8h

# ─── Frontend API URL ───
# For local development
VITE_API_BASE_URL=http://localhost:4000

# ─── Email (optional) ───
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=votre-email
# SMTP_PASS=votre-mot-de-passe
# REPORT_EMAIL=destinataire@example.com
