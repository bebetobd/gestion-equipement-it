# Copier ce fichier en .env et remplir les valeurs

# Chaîne de connexion PostgreSQL (Neon, Railway, Supabase, local…)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Secret JWT — mettre une valeur longue et aléatoire en production
JWT_SECRET=changez-cette-valeur-en-production

# URL du backend (laisser vide en production Vercel — même domaine)
# VITE_API_BASE_URL=http://localhost:4000
